<!DOCTYPE suite SYSTEM "http://testng.org/testng-1.0.dtd">
<suite name="Sanity Test Suite2" parallel="classes" thread-count="3">
   <listeners>
      <listener class-name="org.alfresco.share.RetryListener"/>
   </listeners>

   <test name="Sanity Tests2">
      <groups>
         <run>
            <include name="sanity"/>
            <include name="share"/>
            <include name="regression"/>
            <exclude name="integration"/>
            <exclude name="unit"/>
            <exclude name="SmartFolders"/>
            <exclude name="ExternalUsers"/>
            <exclude name="office"/>
            <exclude name="TransformationServer"/>
            <exclude name="xsstests"/>
            <exclude name="admin-tools"/>
            <exclude name="google-docs"/>
            <include name="sites"/>
            <exclude name="user-dashboard"/>
            <exclude name="site-dashboard"/>
            <exclude name="user"/>
            <exclude name="auth"/>
            <exclude name="FlakyTests"/>
         </run>
      </groups>
      <packages>
         <package name="org.alfresco.share.alfrescoContent.workingWithFilesAndFolders.editingFiles"/>
         <package name="org.alfresco.share.alfrescoContent.workingWithFilesOutsideTheLibrary.repository.additionalActions"/>
         <package name="org.alfresco.share.alfrescoContent.workingWithFilesOutsideTheLibrary.myFiles.taggingAndSocialFeatures"/>
         <package name="org.alfresco.share.alfrescoContent.workingWithFilesOutsideTheLibrary.myFiles"/>
         <package name="org.alfresco.share.alfrescoContent.workingWithFilesOutsideTheLibrary.sharedFiles.actions"/>
         <package name="org.alfresco.share.alfrescoContent.workingWithFilesOutsideTheLibrary.sharedFiles.additionalActions"/>
         <package name="org.alfresco.share.alfrescoContent.workingWithFilesOutsideTheLibrary.repository"/>
         <package name="org.alfresco.share.alfrescoContent.workingWithFilesOutsideTheLibrary.sharedFiles"/>
      </packages>
   </test>
</suite>
